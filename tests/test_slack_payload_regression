def test_slack_payload_regression():
    notifier = SlackWebhookNotifier(webhook_url="https://example.com")

    event = CoreEvent(
        error_signature="azure.runtime.execution.oom",
        transition="RESOLVED→NEW",
        plane="azure",
        component="runtime",
        source_or_model="phi",
        error_type="oom",
        occurred_at_utc=datetime(
            2026, 3, 28, 14, 30, 0, tzinfo=timezone.utc
        ),
    )

    payload = notifier._build_payload(event)

    header = payload["blocks"][0]["text"]["text"]
    assert "SSP Error Regression" in header
    fields = payload["blocks"][1]["fields"]
    joined = " ".join(f["text"] for f in fields)
    assert "azure.runtime.execution.oom" in joined
    assert "RESOLVED→NEW" in joined
    assert "azure" in joined
    assert "runtime" in joined
    assert "phi" in joined
    assert "oom" in joined
    assert "KST" in joined

    